<style>
  .hero-section {
    position: relative;
    height: 70vh;
    min-height: 520px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background-image: url('https://images.unsplash.com/photo-1581092916376-2236b2456667?q=80&w=2070&auto=format&fit=crop');
    background-size: cover;
    background-position: center;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,12,14,0.92) 45%, rgba(10,12,14,0.5) 100%),
      linear-gradient(to top, rgba(10,12,14,0.8) 0%, transparent 40%);
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
  }

  /* Ticker */
  .hero-ticker {
    position: absolute;
    bottom: 48px;
    left: 0;
    right: 0;
    z-index: 5;
    overflow: hidden;
    border-top: 1px solid rgba(255,255,255,0.06);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    padding: 8px 0;
    background: rgba(255,255,255,0.02);
  }
  .hero-ticker__inner {
    display: flex;
    gap: 2.5rem;
    width: fit-content;
    animation: ticker 20s linear infinite;
    white-space: nowrap;
  }
  .hero-ticker__inner span {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    font-family: sans-serif;
  }
  .hero-ticker__inner .sep { color: #E8401A; }
  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 10;
    color: white;
    padding: 0 clamp(20px, 5vw, 80px);
    max-width: 900px;
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: 24px;
  }
  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #E8401A;
    animation: pulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.6); }
  }

  h1 {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 24px;
  }
  h1 .line-1,
  h1 .line-2 {
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 800;
    line-height: 0.93;
    letter-spacing: -0.03em;
    color: white;
    display: block;
    font-family: sans-serif;
  }
  h1 .line-3 {
    font-size: clamp(3rem, 9vw, 7rem);
    font-weight: 800;
    line-height: 0.93;
    letter-spacing: -0.03em;
    color: #E8401A;
    display: block;
    font-family: sans-serif;
  }

  .hero-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    line-height: 1.7;
    max-width: 420px;
    margin-bottom: 36px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #E8401A;
    color: white;
    padding: 13px 24px;
    border-radius: 6px;
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .btn-primary:hover {
    background: #c93414;
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(232,64,26,0.4);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.7);
    padding: 13px 24px;
    border-radius: 6px;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.25s ease;
  }
  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.35);
    color: white;
  }

  @media (max-width: 600px) {
    h1 .line-1, h1 .line-2, h1 .line-3 {
      font-size: 3rem;
    }
    .hero-content {
      padding: 0 20px;
    }
  }
</style>
