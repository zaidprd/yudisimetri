---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'Tentang Kami' },
  { href: '/#kontak', label: 'Kontak', id: 'kontak-link' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href.includes('#')) return false;
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header id="site-header">
  <div class="container header-inner">
    <a href="/" class="header-logo" aria-label="Beranda Simetri Panel">
      <img src="/img/logosales.webp" alt="Logo Tri Yudhi Sales Panel Simetri" />
    </a>

    <nav class="main-nav" role="navigation" aria-label="Menu Utama">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
          data-nav={link.id}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="https://wa.me/6281213351911"
      class="header-cta"
      target="_blank"
      rel="noopener"
      aria-label="Hubungi via WhatsApp"
    >
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
