---
import { Image } from 'astro:assets';
import imgLogo from '../assets/img/logosales.webp';

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'Tentang Kami' },
  { href: '/#kontak', label: 'Kontak' },
  { href: '/blog', label: 'Blog' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href.includes('#')) return false;

  if (href === '/') {
    return currentPath === '/';
  }

  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header id="site-header">
  <div class="container header-inner">

    <a href="/" class="header-logo" aria-label="Beranda Simetri Panel">
      <Image
        src={imgLogo}
        alt="Logo Tri Yudhi Sales Panel Simetri"
      />
    </a>

    <nav class="main-nav" role="navigation" aria-label="Menu Utama">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${isActive(link.href) ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <a
      href="https://wa.me/628121342383"
      class="header-cta"
      target="_blank"
      rel="noopener"
      aria-label="Hubungi via WhatsApp"
    >
      <svg
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>

      <span class="cta-text">
        Minta Penawaran
      </span>
    </a>

    <button
      class="hamburger"
      id="menu-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>

  <div
    class="mobile-menu"
    id="mobile-menu"
    aria-hidden="true"
  >
    <nav>

      {navLinks.map((link) => (
        <a
          href={link.href}
          class="mobile-nav-link"
        >
          {link.label}
        </a>
      ))}

      <a
        href="https://wa.me/628121342383"
        class="mobile-wa-btn"
        target="_blank"
        rel="noopener"
      >
        Hubungi via WhatsApp
      </a>

    </nav>
  </div>
</header>

<script>
  let initialized = false;

  function initHeader() {
    if (initialized) return;
    initialized = true;

    const header = document.getElementById('site-header');
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');

    if (!header || !toggle || !menu) return;

    const updateHeader = () => {
      header.classList.toggle('scrolled', window.scrollY > 60);
    };

    updateHeader();

    window.addEventListener('scroll', updateHeader, {
      passive: true,
    });

    toggle.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('open');

      toggle.classList.toggle('active', isOpen);

      toggle.setAttribute(
        'aria-expanded',
        String(isOpen)
      );

      menu.setAttribute(
        'aria-hidden',
        String(!isOpen)
      );
    });

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        toggle.classList.remove('active');

        toggle.setAttribute(
          'aria-expanded',
          'false'
        );

        menu.setAttribute(
          'aria-hidden',
          'true'
        );
      });
    });

    if (window.location.pathname === '/') {

      const sections = ['produk', 'kontak'];
      const navItems =
        document.querySelectorAll('.nav-link');

      const updateActiveSection = () => {
        let current = '';

        sections.forEach((id) => {
          const section =
            document.getElementById(id);

          if (
            section &&
            window.scrollY >=
              section.offsetTop - 140
          ) {
            current = id;
          }
        });

        navItems.forEach((item) => {
          const href =
            item.getAttribute('href') || '';

          item.classList.remove('active');

          if (
            current &&
            href === `/#${current}`
          ) {
            item.classList.add('active');
          }

          if (
            !current &&
            href === '/'
          ) {
            item.classList.add('active');
          }
        });
      };

      updateActiveSection();

      window.addEventListener(
        'scroll',
        updateActiveSection,
        { passive: true }
      );
    }
  }

  initHeader();

  document.addEventListener(
    'astro:page-load',
    initHeader
  );
</script>

<style>
  :root {
    --transition: 0.3s ease;
    --c-primary-dark: #c93414;
  }

  #site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    transition:
      background var(--transition),
      box-shadow var(--transition);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 80px;
    gap: 2rem;
  }

  #site-header:not(.scrolled) {
    background:
      linear-gradient(
        180deg,
        rgba(15,19,24,0.85) 0%,
        transparent 100%
      );
  }

  #site-header:not(.scrolled)
  .header-logo img {
    filter: brightness(0) invert(1);
  }

  #site-header:not(.scrolled)
  .nav-link {
    color: rgba(255,255,255,0.9);
  }

  #site-header:not(.scrolled)
  .hamburger span {
    background: white;
  }

  #site-header.scrolled {
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    box-shadow:
      0 1px 0 rgba(0,0,0,0.08),
      0 4px 16px rgba(0,0,0,0.06);
  }

  #site-header.scrolled .nav-link {
    color: var(--c-dark);
  }

  #site-header.scrolled
  .hamburger span {
    background: var(--c-dark);
  }

  .header-logo img {
    width: auto;
    height: 36px;
    transition: filter var(--transition);
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-left: auto;
  }

  .nav-link {
    position: relative;
    padding: 0.5rem 0.85rem;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 500;
    transition:
      color var(--transition),
      background var(--transition);
  }

  .nav-link::after {
    content: '';
    position: absolute;
    left: 50%;
    right: 50%;
    bottom: 2px;
    height: 2px;
    background: var(--c-primary);
    border-radius: 2px;
    transition:
      left var(--transition),
      right var(--transition);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    left: 0.85rem;
    right: 0.85rem;
  }

  .nav-link.active {
    color: var(--c-primary) !important;
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    background: var(--c-primary);
    color: white;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
    transition:
      background var(--transition),
      transform var(--transition),
      box-shadow var(--transition);
  }

  .header-cta:hover {
    background: var(--c-primary-dark);
    transform: translateY(-1px);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
  }

  .hamburger span {
    width: 24px;
    height: 2px;
    border-radius: 999px;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
  }

  .hamburger.active span:nth-child(1) {
    transform:
      translateY(7px)
      rotate(45deg);
  }

  .hamburger.active span:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active span:nth-child(3) {
    transform:
      translateY(-7px)
      rotate(-45deg);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: 80px;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: var(--c-dark);
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .mobile-menu.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    padding: 0.85rem 1rem;
    border-radius: 6px;
    color: rgba(255,255,255,0.85);
    font-weight: 500;
  }

  .mobile-wa-btn {
    margin-top: 1rem;
    padding: 0.85rem;
    border-radius: 8px;
    background: #25D366;
    color: white;
    text-align: center;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .main-nav,
    .header-cta {
      display: none;
    }

    .hamburger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }
  }

  @media (max-width: 480px) {
    .cta-text {
      display: none;
    }
  }
</style>