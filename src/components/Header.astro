    <nav class="main-nav" role="navigation" aria-label="Menu Utama">
      {navLinks.map(link => (
        <a href={link.href} class={`nav-link ${isActive(link.href) ? 'active' : ''}`}>
          {link.label}
        </a>
      ))}
    </nav>
    <a href="https://wa.me/6281213351911" class="header-cta" target="_blank" rel="noopener">
