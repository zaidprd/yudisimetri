<!-- Overlay & Drawer di LUAR header — langsung di body level -->
<div class="mobile-overlay" id="mobile-overlay" aria-hidden="true"></div>
<div class="mobile-drawer" id="mobile-menu" aria-hidden="true" inert role="dialog" aria-label="Menu navigasi">
  <div class="drawer-header">
    <img src="/img/logosales.webp" alt="Logo Simetri" width="120" height="30" loading="lazy" class="drawer-logo" />
    <button class="drawer-close" id="drawer-close" aria-label="Tutup menu">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>
  <nav class="drawer-nav">
    {navLinks.map(link => (
      <a href={link.href} class={`drawer-link ${isActive(link.href) ? 'active' : ''}`}>
        {link.label}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    ))}
  </nav>
  <div class="drawer-footer">
    <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20konsultasi%20panel%20listrik" class="drawer-wa" target="_blank" rel="noopener">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      Konsultasi via WhatsApp
    </a>
    <p class="drawer-tagline">Sales Panel Maker Simetri</p>
  </div>
</div>

<script>
  function initHeader() {
    const header   = document.getElementById('site-header');
    const toggle   = document.getElementById('menu-toggle');
    const drawer   = document.getElementById('mobile-menu');
    const overlay  = document.getElementById('mobile-overlay');
    const closeBtn = document.getElementById('drawer-close');

    if (!header || !toggle || !drawer || !overlay) return;

    // Scroll effect
    const onScroll = () => header.classList.toggle('scrolled', window.scrollY > 60);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    function openDrawer() {
      drawer.classList.add('open');
      overlay.classList.add('open');
      toggle.classList.add('active');
      toggle.setAttribute('aria-expanded', 'true');
      drawer.setAttribute('aria-hidden', 'false');
      drawer.removeAttribute('inert');          // biarkan fokus masuk
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('open');
      overlay.classList.remove('open');
      toggle.classList.remove('active');
      toggle.setAttribute('aria-expanded', 'false');
      drawer.setAttribute('aria-hidden', 'true');
      drawer.setAttribute('inert', '');         // blokir fokus & klik
      document.body.style.overflow = '';
    }

    // Clone toggle untuk hindari event dobel
    const newToggle = toggle.cloneNode(true) as HTMLElement;
    toggle.parentNode?.replaceChild(newToggle, toggle);
    newToggle.addEventListener('click', () => {
      drawer.classList.contains('open') ? closeDrawer() : openDrawer();
    });

    // Clone close button
    const newClose = document.getElementById('drawer-close');
    if (newClose) {
      const clonedClose = newClose.cloneNode(true) as HTMLElement;
      newClose.parentNode?.replaceChild(clonedClose, newClose);
      clonedClose.addEventListener('click', closeDrawer);
    }

    overlay.addEventListener('click', closeDrawer);

    drawer.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        closeDrawer();
        const href = link.getAttribute('href') || '';
        if (href.includes('#') && !href.startsWith('http')) {
          const hash = href.split('#')[1];
          if (window.location.pathname !== '/') {
            sessionStorage.setItem('scrollTo', hash);
          }
        }
      });
    });

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeDrawer();
    });

    const scrollTarget = sessionStorage.getItem('scrollTo');
    if (scrollTarget) {
      sessionStorage.removeItem('scrollTo');
      setTimeout(() => {
        const el = document.getElementById(scrollTarget);
        if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 200);
    }

    if (window.location.pathname === '/') {
      const sections = ['produk', 'kontak'];
      const navItems = document.querySelectorAll('.nav-link');
      const updateActive = () => {
        let current = '';
        sections.forEach(id => {
          const el = document.getElementById(id);
          if (el && window.scrollY >= el.offsetTop - 140) current = id;
        });
        navItems.forEach(item => {
          const href = item.getAttribute('href') || '';
          item.classList.remove('active');
          if (current && href === `/#${current}`) item.classList.add('active');
          else if (!current && href === '/') item.classList.add('active');
        });
      };
      updateActive();
      window.addEventListener('scroll', updateActive, { passive: true });
    }
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
  document.addEventListener('astro:page-load', initHeader);
</script>

<style>
  #site-header {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 9999;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }
  .header-inner {
    display: flex; align-items: center; justify-content: space-between;
    height: 76px; gap: 1.5rem;
  }

  /* TRANSPARENT */
  #site-header:not(.scrolled) {
    background: linear-gradient(180deg, rgba(10,12,14,0.9) 0%, transparent 100%);
  }
  #site-header:not(.scrolled) .header-logo img { filter: brightness(0) invert(1); }
  #site-header:not(.scrolled) .nav-link { color: rgba(255,255,255,0.8); }
  #site-header:not(.scrolled) .hamburger span { background: rgba(255,255,255,0.9); }

  /* SCROLLED */
  #site-header.scrolled {
    background: rgba(10,12,14,0.97);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255,255,255,0.06);
    box-shadow: 0 4px 24px rgba(0,0,0,0.35);
  }
  #site-header.scrolled .header-logo img { filter: none; }
  #site-header.scrolled .nav-link { color: rgba(255,255,255,0.65); }
  #site-header.scrolled .hamburger span { background: rgba(255,255,255,0.85); }

  .header-logo img { height: 34px; width: auto; transition: filter 0.3s ease, opacity 0.3s ease; }
  .header-logo:hover img { opacity: 0.8; }

  .main-nav { display: flex; align-items: center; gap: 0; margin-left: auto; }
  .nav-link {
    position: relative; padding: 0.45rem 0.9rem; border-radius: 5px;
    font-size: 0.825rem; font-weight: 500; letter-spacing: 0.01em;
    transition: color 0.25s ease;
  }
  .nav-link::after {
    content: ''; position: absolute;
    left: 0.9rem; right: 0.9rem; bottom: 0;
    height: 1.5px; background: var(--gold-500); border-radius: 1px;
    transform: scaleX(0); transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .nav-link:hover { color: rgba(255,255,255,0.95) !important; }
  .nav-link:hover::after, .nav-link.active::after { transform: scaleX(1); }
  .nav-link.active { color: white !important; }

  .header-cta {
    display: flex; align-items: center; gap: 7px;
    padding: 0.5rem 1.1rem; border-radius: 999px;
    background: var(--gold-500); color: var(--bg-base);
    font-size: 0.82rem; font-weight: 700; white-space: nowrap;
    transition: background 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
    box-shadow: 0 0 24px var(--gold-glow);
  }
  .header-cta:hover { background: var(--gold-400); transform: translateY(-1px); box-shadow: 0 0 40px var(--gold-glow-strong); }

  .hamburger {
    display: none;
    flex-direction: column; justify-content: center; align-items: center;
    gap: 5px; width: 44px; height: 44px;
    border: none; background: rgba(255,255,255,0.1); border-radius: 8px;
    cursor: pointer; padding: 0;
    position: relative; z-index: 9999;
    -webkit-tap-highlight-color: rgba(201,168,76,0.2);
    touch-action: manipulation;
    transition: background 0.2s ease;
  }
  .hamburger:hover { background: rgba(255,255,255,0.18); }
  .hamburger:active { background: rgba(201,168,76,0.25); }
  .hamburger span {
    display: block; width: 22px; height: 2px;
    border-radius: 999px; background: white;
    transition: transform 0.3s cubic-bezier(0.16,1,0.3,1), opacity 0.25s ease;
    pointer-events: none;
  }
  .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* OVERLAY — di luar header, langsung di body */
  .mobile-overlay {
    position: fixed; inset: 0;
    z-index: 99998;
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .mobile-overlay.open { opacity: 1; pointer-events: all; }

  /* DRAWER — di luar header, langsung di body */
  .mobile-drawer {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(320px, 85vw);
    z-index: 99999;
    background: #0F1318;
    border-left: 1px solid rgba(255,255,255,0.08);
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    pointer-events: none;
  }
  .mobile-drawer.open { transform: translateX(0); pointer-events: all; }

  .drawer-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    flex-shrink: 0;
  }
  .drawer-logo { filter: brightness(0) invert(1); height: 28px; width: auto; }
  .drawer-close {
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 8px;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.7); cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
    touch-action: manipulation;
  }
  .drawer-close:hover { background: rgba(255,255,255,0.14); color: white; }

  .drawer-nav { flex: 1; padding: 0.5rem 0; display: flex; flex-direction: column; overflow-y: auto; }
  .drawer-link {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1rem 1.5rem;
    color: rgba(255,255,255,0.7);
    font-size: 1rem; font-weight: 500;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: color 0.2s ease, background 0.2s ease;
    min-height: 56px; cursor: pointer;
    -webkit-tap-highlight-color: rgba(201,168,76,0.12);
    touch-action: manipulation;
  }
  .drawer-link:hover, .drawer-link:focus { color: white; background: rgba(255,255,255,0.05); }
  .drawer-link.active { color: var(--gold-400); background: rgba(201,168,76,0.08); border-left: 3px solid var(--gold-500); }
  .drawer-link svg { opacity: 0.3; flex-shrink: 0; transition: opacity 0.2s, transform 0.2s; }
  .drawer-link:hover svg { opacity: 0.7; transform: translateX(4px); }
  .drawer-link.active svg { opacity: 0.5; color: var(--gold-400); }

  .drawer-footer { padding: 1.5rem; border-top: 1px solid rgba(255,255,255,0.06); flex-shrink: 0; }
  .drawer-wa {
    display: flex; align-items: center; justify-content: center; gap: 0.6rem;
    width: 100%; padding: 1rem;
    background: #25D366; color: white;
    border-radius: 10px; font-weight: 700; font-size: 0.9rem;
    transition: background 0.2s ease, transform 0.2s ease;
    min-height: 54px;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }
  .drawer-wa:hover { background: #1ebe5d; transform: translateY(-1px); }
  .drawer-wa:active { transform: translateY(0); background: #17a84e; }
  .drawer-tagline { text-align: center; margin-top: 0.85rem; font-size: 0.7rem; color: rgba(255,255,255,0.2); letter-spacing: 0.06em; }

  @media (max-width: 900px) {
    .main-nav, .header-cta { display: none; }
    .hamburger { display: flex; }
  }
  @media (max-width: 480px) {
    .cta-text { display: none; }
  }
</style>