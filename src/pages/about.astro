---
// src/pages/about.astro (FINAL - Perbaikan Layout Teks & Gambar)
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Me - Tri Yudhi, Sales Panel Listrik Simetri">
  
  <!-- 1. HERO SECTION (Tidak berubah) -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1>About Me</h1>
        <p>Tri Yudhi - Sales Panel Listrik PT Sinar Metrindo Perkasa</p>
      </div>
    </div>
  </section>

  <!-- 2. KONTEN UTAMA -->
  <section class="page-section">
    <div class="container about-container">
      
      <!-- ================================================== -->
      <!-- BAGIAN ATAS: GRID DUA KOLOM (INI YANG DIPERBAIKI) -->
      <!-- ================================================== -->
      <div class="intro-grid">
        
        <!-- Kolom Kiri: Teks dan Tombol -->
        <div class="intro-text">
          <p class="subtitle">ABOUT ME</p>
          <h2>Join Simetri</h2>
          <div class="divider"></div>
          <p>
            Saya bergabung dengan simetri (PT. Sinar metrindo Perkasa) sejak tahun 2007. Di tahun pertama saya memulai karir saya dengan menjadi staf estimator.
          </p>
          <p>
            Sempat menjadi estimator selama 3 tahun membuat saya lebih paham tentang panel listrik (panel maker). Sehingga saya terjun menjadi sales.
          </p>
          <p>
            Tujuan saya menjadi sales adalah dengan bekal ilmu estimator yang saya dapat agar memudahkan dalam memberikan penjelasan dan pemahaman kepada calon client simetri.
          </p>
          <!-- Tombol dipindahkan ke sini -->
          <a href="https://wa.me/628121342383" class="cta-button" target="_blank">HUBUNGI SEGERA &rarr;</a>
        </div>

        <!-- Kolom Kanan: Gambar -->
        <div class="intro-image">
          <img src="/img/sales-simetri-dapat.webp" alt="Sales Simetri Mendapat Penghargaan">
          <p class="caption">sales simetri dapat penghargaan</p>
        </div>
      </div>

      <!-- ================================================== -->
      <!-- KONTEN BAWAH (Karir & Prestasi, tidak berubah ) -->
      <!-- ================================================== -->
      <div class="career-section">
        <h2>Karir</h2>
        <div class="timeline">
          <div class="timeline-item">
            <p class="role">Estimator 2007 - 2009</p>
            <div class="progress-bar"><div class="progress" style="width: 30%;"></div></div>
          </div>
          <div class="timeline-item">
            <p class="role">Sales 2010 - 2017</p>
            <div class="progress-bar"><div class="progress" style="width: 70%;"></div></div>
          </div>
          <div class="timeline-item">
            <p class="role">2017-2022 Team Leader</p>
            <div class="progress-bar"><div class="progress" style="width: 85%;"></div></div>
          </div>
          <div class="timeline-item">
            <p class="role">Sales Manager - 2022 - Sekarang</p>
            <div class="progress-bar"><div class="progress" style="width: 100%;"></div></div>
          </div>
        </div>
      </div>

      <div class="achievement-section">
        <h2>Prestasi</h2>
        <p>
          Setelah saya fokus menjadi sales panel listrik di simetri dari tahun ke tahun selalu menjadi top sales. Proyek swasta maupun proyek pemerintah sudah banyak yang saya tangani.
        </p>
        <p>
          Jangan ragu untuk konsultasi dengan yudhi sales simetri, segera minta penawaran harga untuk proyek-proyek anda.
        </p>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* === HERO SECTION (Sama) === */
  .hero-section { position: relative; height: 50vh; display: flex; align-items: center; justify-content: center; color: white; background-image: url('/img/Panel-matrix-simetri.webp'); background-size: cover; background-position: center; margin-top: -80px; }
  .hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.6); }
  .hero-section .container { position: relative; z-index: 2; }
  .hero-content { text-align: center; padding-top: 5rem; }
  .hero-content h1 { font-size: 3rem; font-weight: 900; margin: 0 0 0.5rem 0; }
  .hero-content p { font-size: 1.1rem; line-height: 1.6; margin: 0; opacity: 0.9; }

  /* === KONTEN UTAMA === */
  .page-section { padding: 5rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .about-container { max-width: 1000px; }

  /* === CSS GRID YANG DIPERBAIKI === */
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-bottom: 5rem; /* Beri jarak lebih ke section karir */
  }
  .intro-text .subtitle { font-weight: bold; color: #1abc9c; margin-bottom: 0.5rem; letter-spacing: 1px; }
  .intro-text h2 { font-family: 'Georgia', serif; font-size: 3rem; font-weight: 500; margin-top: 0; margin-bottom: 1.5rem; color: #222; }
  .divider { width: 50px; height: 3px; background-color: #1abc9c; margin-bottom: 2rem; }
  .intro-text p { font-size: 1rem; line-height: 1.8; color: #555; margin-bottom: 1.5rem; }
  
  .cta-button { display: inline-block; margin-top: 1rem; background-color: #1abc9c; color: white; padding: 0.8rem 2rem; border-radius: 8px; text-decoration: none; font-weight: bold; transition: all 0.2s; box-shadow: 0 4px 10px rgba(26, 188, 156, 0.3); }
  .cta-button:hover { background-color: #16a085; transform: translateY(-2px); }

  .intro-image img { width: 100%; height: auto; border-radius: 8px; box-shadow: 0 8px 25px rgba(0,0,0,0.1); }
  .caption { font-style: italic; color: #777; margin-top: 0.5rem; font-size: 0.9rem; text-align: center; }
  
  /* === KONTEN BAWAH (Tidak berubah) === */
  .career-section, .achievement-section { margin-top: 4rem; }
  .career-section h2, .achievement-section h2 { font-size: 2rem; font-weight: 800; margin-bottom: 2rem; color: #222; border-bottom: 3px solid #1abc9c; padding-bottom: 0.5rem; display: inline-block; }
  .timeline { display: flex; flex-direction: column; gap: 1.5rem; }
  .timeline-item { display: block; }
  .timeline-item .role { margin: 0 0 0.5rem 0; font-weight: 600; color: #333; }
  .progress-bar { width: 100%; background-color: #e0e0e0; border-radius: 4px; height: 10px; overflow: hidden; }
  .progress { height: 100%; background-color: #1abc9c; border-radius: 4px; }
  .achievement-section p { font-size: 1.1rem; line-height: 1.8; color: #555; margin-bottom: 1.5rem; }

  /* Responsif */
  @media (max-width: 992px) {
    .intro-grid { grid-template-columns: 1fr; }
  }
</style>
