---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Jual Panel Listrik Jakarta | SIMOSEC, Matrix, LVMDP, Genset – Simetri"
  description="Sales Panel Listrik Simetri Jakarta – SIMOSEC, Panel Matrix, LVMDP, Panel Genset PKG, Kapasitor Bank, Panel Distribusi. Tri Yudhi Sales Manager SMP 18+ tahun pengalaman."
>
  <link slot="head" rel="preload" as="image" href="/img/Panel-matrix-simetri.webp" fetchpriority="high" />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "PT Sinar Metrindo Perkasa (Simetri)",
    "alternateName": "Sales Panel Simetri",
    "url": "https://salespanelsimetri.com",
    "logo": "https://salespanelsimetri.com/img/logosales.webp",
    "image": "https://salespanelsimetri.com/img/Panel-matrix-simetri.webp",
    "description": "Distributor dan panel maker panel listrik premium Jakarta: SIMOSEC, Panel Matrix, LVMDP, Panel Genset PKG, Kapasitor Bank, Panel Distribusi.",
    "telephone": "+6281213351911",
    "priceRange": "$$",
    "foundingDate": "2007",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Aries Niaga Blok A1 No. 3A-3B, Meruya Utara, Kembangan",
      "addressLocality": "Jakarta Barat",
      "postalCode": "11620",
      "addressRegion": "DKI Jakarta",
      "addressCountry": "ID"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": -6.1751,
      "longitude": 106.7908
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+6281213351911",
      "contactType": "sales",
      "availableLanguage": "Indonesian"
    },
    "sameAs": [
      "https://wa.me/6281213351911"
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Produk Panel Listrik",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Panel SIMOSEC" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Panel Matrix" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Panel LVMDP" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Panel Genset PKG" } },
        { "@type": "Offer", "itemOffered": { "@type": "Product", "name": "Panel Kapasitor Bank" } }
      ]
    }
  })} />

  <!-- ═══════════════════════════════════════
       1. HERO
  ═══════════════════════════════════════ -->
  <section class="hero" aria-label="Panel listrik premium untuk industri">
    <img
      class="hero-bg-img"
      src="/img/Panel-matrix-simetri.webp"
      alt=""
      width="1600"
      height="900"
      decoding="async"
      fetchpriority="high"
      aria-hidden="true"
    />
    <div class="hero-gradient" aria-hidden="true"></div>
    <div class="hero-grid" aria-hidden="true"></div>
    <div class="hero-corners" aria-hidden="true">
      <span class="corner corner--tl"></span>
      <span class="corner corner--tr"></span>
      <span class="corner corner--bl"></span>
      <span class="corner corner--br"></span>
    </div>
    <div class="hero-sweep" aria-hidden="true"></div>
    <div class="hero-spotlight" id="hero-spotlight" aria-hidden="true"></div>

    <div class="hero-container container">
      <div class="hero-eyebrow" data-delay="0">
        <span class="eyebrow-dot"></span>
        <span>Trusted Since 2007</span>
      </div>

      <h1 class="hero-title">
        <span class="hero-title-line" data-delay="100">Panel Listrik</span>
        <em class="hero-title-line hero-title-gold" data-delay="220">Premium</em>
        <span class="hero-title-line" data-delay="340">untuk Industri Anda</span>
      </h1>

      <p class="hero-subtitle" data-delay="450">
        PT Sinar Metrindo Perkasa (Simetri) — solusi panel listrik berkualitas tinggi
        untuk distribusi, kontrol, dan proteksi tenaga listrik di seluruh Indonesia.
      </p>

      <div class="hero-actions" data-delay="550">
        <a href="#kontak" class="btn-gold magnetic-btn">
          <span>Hubungi Sales</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="#produk" class="btn-ghost magnetic-btn">Lihat Produk</a>
      </div>

      <div class="hero-stats" data-delay="650">
        <div class="stat-item">
          <span class="stat-num" data-target="18" data-suffix="+">0</span>
          <span class="stat-lbl">Tahun Pengalaman</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num" data-target="500" data-suffix="+">0</span>
          <span class="stat-lbl">Proyek Selesai</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num" data-target="100" data-suffix="%">0</span>
          <span class="stat-lbl">Bergaransi</span>
        </div>
      </div>
    </div>

    <div class="hero-scroll-indicator" aria-hidden="true">
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       2. STATS / NUMBERS
  ═══════════════════════════════════════ -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid stagger">
        <div class="stats-card">
          <div class="stats-card-accent"></div>
          <span class="stats-number">18+</span>
          <span class="stats-unit">Tahun</span>
          <p class="stats-desc">Berpengalaman melayani industri manufaktur, properti, dan infrastruktur.</p>
        </div>
        <div class="stats-card stats-card--featured">
          <div class="stats-card-accent"></div>
          <span class="stats-number">500+</span>
          <span class="stats-unit">Proyek</span>
          <p class="stats-desc">Panel listrik yang telah kami rancang, produksi, dan instalasi di seluruh Indonesia.</p>
        </div>
        <div class="stats-card">
          <div class="stats-card-accent"></div>
          <span class="stats-number">100%</span>
          <span class="stats-unit">Bergaransi</span>
          <p class="stats-desc">Setiap produk dilengkapi garansi penuh dan dukungan purna jual yang responsif.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════
       3. PRODUCTS
  ═══════════════════════════════════════ -->
  <section id="produk" class="products-section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Product Services</span>
        <h2 class="section-heading products-heading">
          Produk Panel<br/>
          <em>Unggulan Kami</em>
        </h2>
        <p class="section-sub">
          Panel SIMOSEC (lisensi Siemens), Panel Matrix type-tested, serta lini panel lokal berkualitas tinggi untuk setiap kebutuhan proyek.
        </p>
      </div>

      <div class="products-grid">
        <div class="product-card tilt-card reveal" >
          <div class="product-card-img">
            <img src="/img/panel-listrik-simosec.webp" alt="Panel SIMOSEC Simetri" loading="lazy" />
            <div class="product-card-overlay"></div>
          </div>
          <div class="product-card-body">
            <span class="product-tag">Lisensi Siemens</span>
            <h3 class="product-name">Panel SIMOSEC</h3>
            <p class="product-desc">Panel tegangan menengah tipe-tested lisensi Siemens, factory-assembled sesuai IEC 62271-200 hingga 24 kV.</p>
            <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20Panel%20SIMOSEC" class="product-link" target="_blank" rel="noopener">
              <span>Minta Penawaran</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="product-card-glow"></div>
        </div>

        <div class="product-card tilt-card reveal" style="transition-delay: 40ms">
          <div class="product-card-img">
            <img src="/img/Panel-matrix-simetri.webp" alt="Panel Matrix Simetri" loading="lazy" />
            <div class="product-card-overlay"></div>
          </div>
          <div class="product-card-body">
            <span class="product-tag">Type Tested</span>
            <h3 class="product-name">Panel Matrix</h3>
            <p class="product-desc">Panel tegangan rendah unggulan Simetri yang telah melalui uji tipe berstandar internasional, kapasitas hingga 6300A.</p>
            <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20Panel%20Matrix" class="product-link" target="_blank" rel="noopener">
              <span>Minta Penawaran</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="product-card-glow"></div>
        </div>

        <div class="product-card tilt-card reveal" style="transition-delay: 80ms">
          <div class="product-card-img">
            <img src="/img/Panel-LVMDP-Simetri.webp" alt="Panel LVMDP Simetri" loading="lazy" />
            <div class="product-card-overlay"></div>
          </div>
          <div class="product-card-body">
            <span class="product-tag">Low Voltage</span>
            <h3 class="product-name">Panel LVMDP</h3>
            <p class="product-desc">Sistem interlock dan interlock dengan coupler. Dirancang untuk distribusi daya tegangan rendah yang andal dan aman.</p>
            <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20Panel%20LVMDP" class="product-link" target="_blank" rel="noopener">
              <span>Minta Penawaran</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="product-card-glow"></div>
        </div>

        <div class="product-card tilt-card reveal" style="transition-delay: 120ms">
          <div class="product-card-img">
            <img src="/img/panel-kontrol-genset-simetri.webp" alt="Panel Genset PKG" loading="lazy" />
            <div class="product-card-overlay"></div>
          </div>
          <div class="product-card-body">
            <span class="product-tag">Control System</span>
            <h3 class="product-name">Panel Genset PKG</h3>
            <p class="product-desc">Sinkronisasi hingga 6 genset dan sinkronisasi antara genset dan PLN. Kontrol otomatis yang presisi.</p>
            <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20Panel%20Genset%20PKG" class="product-link" target="_blank" rel="noopener">
              <span>Minta Penawaran</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="product-card-glow"></div>
        </div>

        <div class="product-card tilt-card reveal" style="transition-delay: 160ms">
          <div class="product-card-img">
            <img src="/img/panel_listrik_distribusi_simetri.webp" alt="Panel Distribusi" loading="lazy" />
            <div class="product-card-overlay"></div>
          </div>
          <div class="product-card-body">
            <span class="product-tag">Distribution</span>
            <h3 class="product-name">Panel Distribusi</h3>
            <p class="product-desc">Kontrol dan proteksi distribusi tenaga listrik ke sub panel dan beban: hydrant, lighting, lift, dan lainnya.</p>
            <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20Panel%20Distribusi" class="product-link" target="_blank" rel="noopener">
              <span>Minta Penawaran</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="product-card-glow"></div>
        </div>

        <div class="product-card tilt-card reveal" style="transition-delay: 200ms">
          <div class="product-card-img">
            <img src="/img/panel_listrik_simetri_kapasitor.webp" alt="Panel Kapasitor Bank" loading="lazy" />
            <div class="product-card-overlay"></div>
          </div>
          <div class="product-card-body">
            <span class="product-tag">Power Factor</span>
            <h3 class="product-name">Panel Kapasitor Bank</h3>
            <p class="product-desc">Memperkecil daya reaktif untuk efisiensi energi maksimal. Solusi hemat biaya listrik jangka panjang.</p>
            <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20Panel%20Kapasitor%20Bank" class="product-link" target="_blank" rel="noopener">
              <span>Minta Penawaran</span>
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
          <div class="product-card-glow"></div>
        </div>
      </div>
    </div>
  </section>

