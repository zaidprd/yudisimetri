---
import Layout from '../layouts/Layout.astro';

// Menggunakan string path langsung ke folder public/img/
const products = [
  {
    id: "panel-lvmdp",
    name: "Panel LVMDP",
    tagline: "Low Voltage Main Distribution Panel",
    desc: "Sistem proteksi dan distribusi daya listrik utama.",
    features: ["Interlock otomatis", "Kapasitas hingga 6300A"],
    img: "/img/Panel-LVMDP-Simetri.webp",
    alt: "Panel LVMDP Simetri Jakarta"
  },
  {
    id: "panel-genset",
    name: "Panel Genset PKG",
    tagline: "Panel Kontrol Genset",
    desc: "Sinkronisasi genset dan PLN.",
    features: ["Sinkronisasi genset", "ATS otomatis"],
    img: "/img/panel-kontrol-genset-simetri.webp",
    alt: "Panel Genset PKG Simetri"
  }
];

const stats = [
  { value: "18+", label: "Tahun Pengalaman" },
  { value: "500+", label: "Proyek" },
  { value: "100%", label: "Support" },
  { value: "24/7", label: "Konsultasi" },
];

const klienList = [
  { img: "/img/klien/klien-1.webp", alt: "Klien 1" },
  { img: "/img/klien/klien-2.webp", alt: "Klien 2" },
  { img: "/img/klien/klien-3.webp", alt: "Klien 3" },
  { img: "/img/klien/klien-4.webp", alt: "Klien 4" },
];
---

<Layout
  title="Jual Panel Listrik Jakarta"
  description="Sales Panel Listrik Simetri Jakarta"
>

<section class="hero">

  <div class="hero-bg">

    <img
      src="/img/Panel-matrix-simetri.webp"
      alt="Panel Matrix Simetri"
      class="hero-img"
      loading="eager"
      fetchpriority="high"
    />

    <div class="hero-overlay"></div>

  </div>

  <div class="container hero-content">

    <div class="hero-badge">
      PT Sinar Metrindo Perkasa
    </div>

    <h1 class="hero-title">
      Panel Listrik<br />
      Berkualitas Tinggi
    </h1>

    <p class="hero-desc">
      Sales panel listrik Jakarta untuk gedung, industri, dan proyek besar.
    </p>

    <div class="hero-actions">

      <a
        href="https://wa.me/628121342383"
        class="btn-primary"
      >
        WhatsApp Sekarang
      </a>

      <a
        href="#produk"
        class="btn-outline"
      >
        Lihat Produk
      </a>

    </div>

  </div>

</section>

<section class="stats-bar">
  <div class="container stats-grid">

    {stats.map((stat) => (
      <div class="stat-item">
        <strong>{stat.value}</strong>
        <span>{stat.label}</span>
      </div>
    ))}

  </div>
</section>

<section id="produk" class="section-products">

  <div class="container">

    <div class="products-grid">

      {products.map((product) => (

        <article class="product-card">

          <div class="product-image-wrap">

            <img
              src={product.img}
              alt={product.alt}
              class="product-img"
              loading="lazy"
            />

          </div>

          <div class="product-body">

            <h3>{product.name}</h3>

            <p>{product.desc}</p>

          </div>

        </article>

      ))}

    </div>

  </div>

</section>

<style>

.hero{
  position:relative;
  min-height:100vh;
  overflow:hidden;
  display:flex;
  align-items:center;
}

.hero-bg{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
}

.hero-img{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  object-fit:cover;
  object-position:center center;
  z-index:1;
}

.hero-overlay{
  position:absolute;
  inset:0;
  background:linear-gradient(
    to right,
    rgba(0,0,0,.82),
    rgba(0,0,0,.45)
  );
  z-index:2;
}

.hero-content{
  position:relative;
  z-index:5;
  color:white;
  padding-top:120px;
  padding-bottom:80px;
}

.hero-badge{
  display:inline-block;
  padding:10px 18px;
  background:rgba(255,255,255,.1);
  backdrop-filter:blur(8px);
  border-radius:999px;
  margin-bottom:20px;
}

.hero-title{
  font-size:clamp(2.8rem,7vw,5.5rem);
  line-height:1.05;
  font-weight:800;
  margin-bottom:20px;
}

.hero-desc{
  max-width:650px;
  font-size:1.1rem;
  line-height:1.8;
  color:rgba(255,255,255,.8);
  margin-bottom:35px;
}

.hero-actions{
  display:flex;
  gap:16px;
  flex-wrap:wrap;
}

.btn-primary{
  background:#E8401A;
  color:white;
  padding:14px 28px;
  border-radius:10px;
  font-weight:700;
}

.btn-outline{
  border:1px solid rgba(255,255,255,.4);
  color:white;
  padding:14px 28px;
  border-radius:10px;
}

.stats-bar{
  background:#111;
  color:white;
  padding:50px 0;
}

.stats-grid{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:20px;
}

.stat-item{
  text-align:center;
}

.stat-item strong{
  display:block;
  font-size:2rem;
  color:#E8401A;
}

.section-products{
  padding:80px 0;
}

.products-grid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:24px;
}

.product-card{
  background:white;
  border-radius:16px;
  overflow:hidden;
  box-shadow:0 10px 30px rgba(0,0,0,.08);
}

.product-image-wrap{
  height:260px;
  background:#f4f4f4;
}

.product-img{
  width:100%;
  height:100%;
  object-fit:contain;
  padding:20px;
}

.product-body{
  padding:24px;
}

@media(max-width:900px){

  .products-grid{
    grid-template-columns:1fr;
  }

  .stats-grid{
    grid-template-columns:repeat(2,1fr);
  }

}

@media(max-width:600px){

  .hero-title{
    font-size:2.4rem;
  }

}

</style>
