---
import Layout from '../layouts/Layout.astro';
import SmoothScrollHero from '../components/ui/smooth-scroll-hero';

const products = [
  {
    id: "panel-simosec",
    name: "PANEL SIMOSEC",
    tagline: "Air-Insulated Medium-Voltage Switchgear",
    desc: "Panel tegangan menengah tipe-tested lisensi Siemens, factory-assembled sesuai IEC 62271-200. Menggabungkan teknologi air-insulated dengan gas-insulated switching untuk keandalan distribusi daya hingga 24 kV.",
    features: ["Tegangan hingga 24 kV, 25 kA", "Tipe-tested IEC 62271-200", "Metal-enclosed, 3-phase indoor", "Lisensi resmi Siemens"],
    img: "/img/panel-listrik-simosec.webp",
    alt: "Panel SIMOSEC Simetri – Air-Insulated Medium-Voltage Switchgear Jakarta",
    badge: "Lisensi Siemens"
  },
  {
    id: "panel-matrix",
    name: "PANEL MATRIX",
    tagline: "Low Voltage Panel – Type Tested",
    desc: "Panel tegangan rendah unggulan Simetri yang telah melalui serangkaian uji tipe (type-tested) berstandar internasional. Dirancang untuk sistem distribusi daya utama pada gedung bertingkat dan industri berat.",
    features: ["Type-tested bersertifikasi", "Kapasitas hingga 6300A", "Busbar system optimal", "Produk flagship Simetri"],
    img: "/img/Panel-matrix-simetri.webp",
    alt: "Panel Matrix Simetri – Low Voltage Type Tested Panel Jakarta",
    badge: "By Simetri"
  },
  {
    id: "panel-lvmdp",
    name: "PANEL LVMDP",
    tagline: "Low Voltage Main Distribution Panel",
    desc: "Sistem proteksi dan distribusi daya listrik utama. Beberapa fitur utama kami: Sistem interlock dan interlock dengan coupler.",
    features: ["Interlock otomatis", "Kapasitas hingga 6300A", "Interlock dengan coupler"],
    img: "/img/Panel-LVMDP-Simetri.webp",
    alt: "Panel LVMDP Simetri Jakarta",
    badge: null
  },
  {
    id: "panel-genset",
    name: "PANEL GENSET PKG",
    tagline: "Panel Kontrol Genset",
    desc: "Sinkronisasi genset dan PLN. Simetri dapat melakukan sinkronisasi hingga 6 genset dan juga dapat melakukan sinkronisasi antara genset dan PLN ('Back and Forward Synchron').",
    features: ["Sinkronisasi 6 Genset", "ATS otomatis", "Back & Forward Synchron"],
    img: "/img/panel-kontrol-genset-simetri.webp",
    alt: "Panel Genset PKG Simetri",
    badge: null
  },
  {
    id: "panel-kapasitor",
    name: "PANEL CAPASITOR BANK",
    tagline: "Power Factor Correction",
    desc: "Panel Capasitor berfungsi untuk memperkecil daya reaktif, menghemat pemakaian listrik, dan menjaga kestabilan tegangan.",
    features: ["Memperkecil Daya Reaktif", "Menghemat Biaya Listrik", "Komponen Berkualitas"],
    img: "/img/panel_listrik_simetri_kapasitor.webp",
    alt: "Panel Kapasitor Bank Simetri",
    badge: null
  },
  {
    id: "panel-distribusi",
    name: "PANEL DISTRIBUSI",
    tagline: "Sub Distribution Panel",
    desc: "Sistem Control dan Proteksi distribusi tenaga listrik ke sub panel dan beban seperti hydrant, lighting, lift, dll.",
    features: ["Sistem Kontrol Handal", "Proteksi Sub Panel", "Komponen Standar SNI"],
    img: "/img/panel_listrik_distribusi_simetri.webp",
    alt: "Panel Distribusi Simetri",
    badge: null
  }
];

const stats = [
  { value: "18+", label: "Tahun Pengalaman" },
  { value: "500+", label: "Proyek" },
  { value: "100%", label: "Support" },
  { value: "24/7", label: "Konsultasi" },
];

const klienList = [
  { img: "/img/klien/klien-1.webp", alt: "Klien Panel Simetri – Bandara Internasional" },
  { img: "/img/klien/klien-2.webp", alt: "Klien Panel Simetri – Rumah Sakit" },
  { img: "/img/klien/klien-3.webp", alt: "Klien Panel Simetri – Bank Indonesia" },
  { img: "/img/klien/klien-4.webp", alt: "Klien Panel Simetri – Gedung Perkantoran" },
];
---

<Layout
  title="Jual Panel Listrik Jakarta | SIMOSEC, Matrix, LVMDP, Genset – Simetri"
  description="Sales Panel Listrik Simetri Jakarta – SIMOSEC, Panel Matrix, LVMDP, Panel Genset PKG, Kapasitor Bank, Panel Distribusi. Tri Yudhi Sales Manager SMP 18+ tahun pengalaman."
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href="/img/Panel-matrix-simetri.webp"
    fetchpriority="high"
  />

<section class="hero-wrapper" aria-label="Beranda Panel Maker Simetri">
  <SmoothScrollHero
    client:load
    desktopImage="/img/Panel-matrix-simetri.webp"
    mobileImage="/img/Panel-matrix-simetri.webp"
    scrollHeight={1500}
    initialClipPercentage={25}
    finalClipPercentage={75}
  />
  <div class="hero-text-layer">
    <div class="hero-readability-overlay"></div>
    <div class="container hero-content">
      <div class="hero-eyebrow"><span class="dot"></span>PT Sinar Metrindo Perkasa</div>
      <h1 class="hero-title">
        <span class="line line-1">PANEL</span>
        <span class="line line-2">MAKER</span>
        <span class="line line-3">SIMETRI</span>
      </h1>
      <div class="hero-bottom">
        <p class="hero-desc">Tri Yudhi — Sales Manager SMP sejak 2007. Panel Maker terbaik yang masih eksis dan terpercaya di Indonesia. Segera hubungi team sales Simetri untuk konsultasi gratis.</p>
        <div class="hero-actions">
          <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20konsultasi%20panel%20listrik" class="btn-primary" target="_blank" rel="noopener">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp Sekarang
          </a>
          <a href="#produk" class="btn-ghost">Lihat Produk <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="stats-bar">
  <div class="container stats-grid">
    {stats.map((stat, i) => (
      <div class="stat-item">
        <strong>{stat.value}</strong>
        <span>{stat.label}</span>
        {i < stats.length - 1 && <div class="stat-divider"></div>}
      </div>
    ))}
  </div>
</section>

<section id="produk" class="section-products">
  <div class="container">
    <div class="section-header">
      <div class="section-label"><span class="label-num">01</span><span>Product Services</span></div>
      <div class="section-heading-wrap">
        <h2 class="section-title-main">PRODUK<br /><em>UNGGULAN</em></h2>
        <p class="section-subtitle-main">Panel SIMOSEC (lisensi Siemens), Panel Matrix (type-tested), serta lini panel lokal berkualitas tinggi untuk setiap kebutuhan proyek.</p>
      </div>
    </div>
    <div class="products-grid">
      {products.map((product, i) => (
        <article class="product-card" id={product.id}>
          <div class="product-num">0{i + 1}</div>
          {product.badge && <div class="product-badge">{product.badge}</div>}
          <div class="product-image-wrap">
            <img
              src={product.img}
              alt={product.alt}
              class="product-img"
              width="400"
              height="300"
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding={i < 2 ? 'sync' : 'async'}
            />
          </div>
          <div class="product-body">
            <span class="product-tagline">{product.tagline}</span>
            <h3>{product.name}</h3>
            <p class="product-desc-text">{product.desc}</p>
            <ul class="product-features">
              {product.features.map((f) => <li><span class="feat-icon">✦</span>{f}</li>)}
            </ul>
            <a href={`https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20informasi%20${encodeURIComponent(product.name)}`} class="read-more-btn" target="_blank" rel="noopener">
              Minta Penawaran
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section id="kontak" class="section-cta-v2">
  <div class="cta-bg-text" aria-hidden="true">KONTAK</div>
  <div class="container cta-grid">
    <div class="cta-image-wrap">
      <div class="cta-img-frame">
        <img src="/img/yudi-sales-simetri.webp" alt="Tri Yudhi Sales Manager Panel Listrik Simetri" class="cta-img" loading="lazy" width="600" height="460" />
      </div>
      <div class="cta-badge"><span class="badge-dot"></span>Siap Konsultasi</div>
    </div>
    <div class="cta-text-col">
      <div class="section-label"><span class="label-num">02</span><span>Hubungi Kami</span></div>
      <h2>Dapatkan<br /><em>Penawaran</em><br />Terbaik</h2>
      <p>Kunjungi kantor pusat kami di:<br /><strong>Aries Niaga Blok A1 No. 3A-3B, Jalan Taman Aries, Meruya Utara, Kembangan, Jakarta Barat, DKI 11620</strong></p>
      <a href="https://wa.me/6281213351911?text=Halo%20Pak%20Yudhi%2C%20saya%20ingin%20konsultasi%20panel%20listrik" class="btn-primary" target="_blank" rel="noopener">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Hubungi via WhatsApp
      </a>
    </div>
  </div>
</section>

<section id="project" class="section-klien">
  <div class="container klien-header">
    <div class="section-label"><span class="label-num">03</span><span>Kepercayaan</span></div>
    <h2 class="section-title-main">KLIEN <em>KAMI</em></h2>
  </div>
  <div class="logo-scroller">
    <div class="logo-scroller__inner">
      {klienList.map((k) => <img src={k.img} alt={k.alt} loading="lazy" width="220" height="110" />)}
      {klienList.map((k) => <img src={k.img} alt={k.alt} loading="lazy" width="220" height="110" aria-hidden="true" />)}
    </div>
  </div>
</section>

</Layout>

<style>
  :root {
    --c-accent: #E8401A;
    --c-dark: #0A0C0E;
    --c-mid: #161A1E;
    --c-border: rgba(255,255,255,0.07);
    --c-muted: rgba(255,255,255,0.5);
  }

  /* HERO OVERLAY */
  .hero-wrapper { position: relative; }

  /* Covers only the first viewport — stacks above the animated background */
  .hero-text-layer {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100vh;
    z-index: 20;
    display: flex;
    align-items: center;
    pointer-events: none;
  }

  /* Dark gradient so white text stays readable over any image */
  .hero-readability-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,12,14,0.88) 40%, rgba(10,12,14,0.35) 100%),
      linear-gradient(to top,   rgba(10,12,14,0.92) 0%,  transparent 55%);
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    color: white;
    padding-top: 96px;
    /* Horizontal breathing room — critical on narrow viewports */
    padding-left: 1.5rem;
    padding-right: 1.5rem;
    width: 100%;
    pointer-events: auto;
  }

  .hero-eyebrow { display: flex; align-items: center; gap: 8px; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.55); margin-bottom: 20px; }
  .hero-eyebrow .dot { width: 6px; height: 6px; border-radius: 50%; background: #E8401A; animation: blink 2s ease-in-out infinite; flex-shrink: 0; }
  @keyframes blink { 0%,100% { opacity:1; } 50% { opacity:0.4; } }

  .hero-title { display: flex; flex-direction: column; margin-bottom: 32px; }
  .hero-title .line {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 8vw, 8rem);
    font-weight: 800;
    line-height: 0.92;
    letter-spacing: -0.03em;
    display: block;
  }
  .hero-title .line-1 { color: white; }
  .hero-title .line-2 { color: white; }
  .hero-title .line-3 { color: #E8401A; }

  .hero-bottom { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: end; max-width: 860px; }
  .hero-desc { font-size: 0.93rem; line-height: 1.8; color: rgba(255,255,255,0.55); }
  .hero-actions { display: flex; flex-direction: column; gap: 10px; align-items: flex-start; }

  /* BUTTONS */
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--c-accent); color: white; padding: 13px 24px; border-radius: 6px; font-weight: 700; font-size: 0.88rem; transition: transform 0.2s ease, box-shadow 0.2s ease; white-space: nowrap; }
  .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(232,64,26,0.4); }
  .btn-ghost { display: inline-flex; align-items: center; gap: 8px; border: 1px solid rgba(255,255,255,0.18); color: rgba(255,255,255,0.7); padding: 13px 24px; border-radius: 6px; font-weight: 600; font-size: 0.88rem; transition: border-color 0.2s, color 0.2s; white-space: nowrap; }
  .btn-ghost:hover { border-color: rgba(255,255,255,0.5); color: white; }

  /* STATS */
  .stats-bar { background: var(--c-mid); border-top: 1px solid var(--c-border); border-bottom: 1px solid var(--c-border); }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); }
  .stat-item { position: relative; text-align: center; padding: 32px 16px; }
  .stat-item strong { display: block; font-family: var(--font-display); font-size: 2.5rem; font-weight: 800; color: white; line-height: 1; margin-bottom: 6px; }
  .stat-item strong::first-letter { color: var(--c-accent); }
  .stat-item span { font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--c-muted); }
  .stat-divider { position: absolute; right: 0; top: 25%; height: 50%; width: 1px; background: var(--c-border); }

  /* SECTION SHARED */
  .section-label { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .label-num { font-family: var(--font-display); font-size: 0.65rem; font-weight: 800; color: var(--c-accent); background: rgba(232,64,26,0.1); border: 1px solid rgba(232,64,26,0.2); padding: 3px 8px; border-radius: 3px; }
  .section-label > span:last-child { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #888; }

  /* PRODUCTS */
  .section-products { padding: 80px 0; background: #F7F7F5; }
  .section-header { display: grid; grid-template-columns: auto 1fr; gap: 48px; align-items: start; margin-bottom: 48px; }
  .section-heading-wrap { display: flex; flex-direction: column; gap: 12px; }
  .section-title-main { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 800; color: var(--c-dark); line-height: 1; letter-spacing: -0.06em; }
  .section-title-main em { font-style: normal; color: var(--c-accent); }
  .section-subtitle-main { max-width: 480px; color: #666; line-height: 1.7; font-size: 0.92rem; }

  /* ============================================
     PRODUCTS GRID
     Desktop (>768px)  : 2 kolom
     Mobile  (<=768px) : 1 kolom
  ============================================ */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr); /* DESKTOP: 2 kolom */
    gap: 2px;
    background: #D8D8D4;
    border: 2px solid #D8D8D4;
    border-radius: 14px;
    overflow: hidden;
  }

  .product-card { position: relative; background: white; display: flex; flex-direction: column; transition: background 0.25s ease; overflow: hidden; min-width: 0; }
  .product-card:hover { background: #FAFAF8; }
  .product-num { position: absolute; top: 16px; right: 18px; font-family: var(--font-display); font-size: 0.6rem; font-weight: 800; letter-spacing: 0.1em; color: rgba(0,0,0,0.1); z-index: 2; }
  .product-badge { position: absolute; top: 14px; left: 14px; z-index: 3; background: var(--c-accent); color: white; font-size: 0.58rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; padding: 3px 9px; border-radius: 4px; }
  .product-image-wrap { height: 220px; background: #F2F2EF; display: flex; align-items: center; justify-content: center; padding: 24px; overflow: hidden; }
  .product-img { max-width: 100%; max-height: 100%; object-fit: contain; transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1); }
  .product-card:hover .product-img { transform: scale(1.05); }
  .product-body { padding: 22px 22px 26px; flex-grow: 1; display: flex; flex-direction: column; border-top: 1px solid rgba(0,0,0,0.06); min-width: 0; }
  .product-tagline { font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--c-accent); margin-bottom: 5px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .product-body h3 { font-family: var(--font-display); font-size: 1.05rem; font-weight: 800; color: var(--c-dark); margin-bottom: 8px; line-height: 1.2; }
  .product-desc-text { color: #666; line-height: 1.6; font-size: 0.82rem;  margin-bottom: 12px; flex-grow: 1; }
  .product-features { list-style: none; display: flex; flex-direction: column; gap: 4px; margin-bottom: 18px; }
  .product-features li { display: flex; align-items: center; gap: 6px; font-size: 0.78rem; color: #444; }
  .feat-icon { color: var(--c-accent); font-size: 0.48rem; flex-shrink: 0; }
  .read-more-btn { display: inline-flex; align-items: center; gap: 6px; background: var(--c-dark); color: white; padding: 9px 16px; border-radius: 5px; font-size: 0.78rem; font-weight: 700; align-self: flex-start; transition: background 0.2s ease; white-space: nowrap; }
  .read-more-btn:hover { background: var(--c-accent); }

  /* CTA */
  .section-cta-v2 { background: var(--c-dark); padding: 100px 0; position: relative; overflow: hidden; }
  .cta-bg-text { position: absolute; font-family: var(--font-display); font-size: clamp(6rem, 16vw, 14rem); font-weight: 800; color: rgba(255,255,255,0.02); letter-spacing: -0.04em; top: 50%; left: 50%; transform: translate(-50%, -50%); white-space: nowrap; pointer-events: none; user-select: none; }
  .cta-grid { position: relative; z-index: 2; display: grid; grid-template-columns: 1fr 1.1fr; gap: 70px; align-items: center; }
  .cta-image-wrap { position: relative; }
  .cta-img-frame { border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.06); }
  .cta-img { width: 100%; height: 460px; object-fit: cover; display: block; }
  .cta-badge { position: absolute; bottom: -14px; right: -14px; background: var(--c-accent); color: white; padding: 11px 16px; border-radius: 8px; font-size: 0.75rem; font-weight: 700; display: flex; align-items: center; gap: 8px; box-shadow: 0 8px 24px rgba(232,64,26,0.4); z-index: 3; }
  .badge-dot { width: 7px; height: 7px; border-radius: 50%; background: rgba(255,255,255,0.8); animation: blink 1.5s ease-in-out infinite; }
  .cta-text-col { color: white; }
