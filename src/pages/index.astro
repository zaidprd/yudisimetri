       4. TRUST / ABOUT
  ═══════════════════════════════════════ -->
  <section class="trust-section">
    <div class="container trust-grid">
      <div class="trust-content reveal-left">
        <span class="section-label">Mengapa Simetri</span>
        <h2 class="section-heading trust-heading">
          Dipercaya Ribuan<br/>
          <em>Klien Industri</em>
