---
import Layout from '../layouts/Layout.astro';
import { client, urlFor } from '../lib/sanity';
import { PortableText } from 'astro-portabletext';

export async function getStaticPaths() {
  const query = `*[_type == "post" && defined(slug.current)][] { "slug": slug.current }`;
  const posts = await client.fetch(query);
  return posts.map(post => ({
    params: { slug: post.slug }
  }));
}

const params = Astro.params || {};
const slug = params.slug || null;

if (!slug) {
  throw new Error("Slug tidak ditemukan di params");
}

const detailQuery = `*[_type == "post" && slug.current == $slug][0] {
  title,
  mainImage,
  body,
  publishedAt,
  "authorName": author->name
}`;

const post = await client.fetch(detailQuery, { slug });

// Ambil 3 postingan lain (exclude current slug)
const recentQuery = `*[_type == "post" && slug.current != $slug] | order(publishedAt desc)[0...2] {
  title,
  mainImage,
  "slug": slug.current,
  publishedAt
}`;
const recentPosts = await client.fetch(recentQuery, { slug });

if (!post) {
  return Astro.redirect('/404');
}
---


<Layout title={post.title}>
  <!-- 1. HERO SECTION -->
  <section class="hero-section">
    <div class="hero-overlay"></div>
    <div class="container">
      <div class="hero-content">
        <h1>{post.title}</h1>
      </div>
    </div>
  </section>

  <!-- 2. KONTEN ARTIKEL -->
  <section class="page-section">
    <div class="container article-container">
      
      <div class="article-meta">
        <span>
          Dipublikasikan pada: 
          <strong>{new Date(post.publishedAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}</strong>
        </span>
        {post.authorName && <span>Oleh: <strong>{post.authorName}</strong></span>}
      </div>

      {post.mainImage && (
        <img 
          class="featured-image"
          src={urlFor(post.mainImage).width(1200).height(600).url()} 
          alt={post.mainImage.alt || post.title} 
        />
      )}

      <div class="article-body">
        {post.body ? <PortableText value={post.body} /> : <p>Konten tidak tersedia.</p>}
      </div>

      <div class="back-link-wrapper">
        <a href="/blog" class="back-link">&larr; Kembali ke Semua Artikel</a>
      </div>

      <!-- 3. RECENT POSTS -->
      {recentPosts.length > 0 && (
        <div class="recent-posts">
          <h2>Artikel Terkini</h2>
          <div class="recent-grid">
            {recentPosts.map(rp => (
              <a href={`/blog/${rp.slug}`} class="recent-card">
                {rp.mainImage && (
                  <img src={urlFor(rp.mainImage).width(600).height(400).url()} alt={rp.title} loading="lazy" />
                )}
                <h3>{rp.title}</h3>
                <p>{new Date(rp.publishedAt).toLocaleDateString('id-ID')}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  /* === HERO SECTION === */
  .hero-section {
    position: relative;
    height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    background-image: url('/img/Panel-matrix-simetri.webp');
    background-size: cover;
    background-position: center;
    margin-top: -80px;
  }
  .hero-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.6); }
  .hero-content { text-align: center; padding-top: 10rem; }
  .hero-content h1 { font-size: 3rem; font-weight: 900; margin: 0; }

  /* === KONTEN ARTIKEL === */
  .page-section { padding: 5rem 0; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .article-container { max-width: 800px; }

  .article-meta {
    display: flex; flex-wrap: wrap; gap: 1.5rem; justify-content: center;
    text-align: center; margin-bottom: 2rem; color: #555; font-size: 0.9rem;
  }
  .featured-image {
    width: 100%; height: auto; border-radius: 12px; margin-bottom: 3rem;
    box-shadow: 0 8px 25px rgba(0,0,0,0.1);
  }
  .article-body { line-height: 1.8; font-size: 1.1rem; color: #333; }
  .article-body h2 { font-size: 1.8rem; margin-top: 3rem; margin-bottom: 1rem; }
  .article-body h3 { font-size: 1.5rem; margin-top: 2.5rem; margin-bottom: 1rem; }
  .article-body p { margin-bottom: 1.5rem; }
  .article-body a { color: #1abc9c; text-decoration: underline; }
  .article-body ul, .article-body ol { margin-bottom: 1.5rem; padding-left: 1.5rem; }
  .article-body blockquote {
    border-left: 4px solid #1abc9c; padding-left: 1.5rem;
    margin: 2rem 0; font-style: italic; color: #555;
  }
  .back-link-wrapper {
    text-align: center; margin-top: 4rem; padding-top: 2rem;
    border-top: 1px solid #e0e0e0;
  }
  .back-link {
    display: inline-block; background-color: #f1f1f1; color: #333;
    padding: 0.8rem 1.5rem; border-radius: 8px; text-decoration: none;
    font-weight: bold; transition: background-color 0.2s;
  }
  .back-link:hover { background-color: #e0e0e0; }

  /* === RECENT POSTS === */
  .recent-posts { margin-top: 5rem; }
  .recent-posts h2 {
    text-align: center;
    margin-bottom: 2rem;
    font-size: 2rem;
    font-weight: 700;
  }
  .recent-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }
  .recent-card {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    text-decoration: none;
    color: #333;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .recent-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.15);
  }
  .recent-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }
  .recent-card h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 1rem;
    color: #000;
  }
  .recent-card p {
    font-size: 0.9rem;
    color: #777;
    margin: 0 1rem 1rem;
  }
</style>
