---
// src/layouts/Layout.astro (Dengan Navigasi Instan)
import Header from '../components/Header.astro';
import { ViewTransitions } from 'astro:transitions'; // <-- 1. IMPORT FITUR INI

interface Props {
  title: string;
}
const { title } = Astro.props;
const currentYear = new Date().getFullYear();
---
<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Panel Maker Simetri Jakarta." />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <title>{title}</title>

    <ViewTransitions /> <!-- <-- 2. TAMBAHKAN KOMPONEN INI DI SINI -->

    <style is:global>
      @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap'  );
      body {
        font-family: 'Roboto', sans-serif;
        margin: 0;
        background-color: #fff;
        color: #333;
      }
    </style>
  </head>
  <body>
    <Header />
    
    <!-- PENTING: Bungkus <slot /> dengan <main> -->
    <main id="page-content">
      <slot />
    </main>

    <footer id="site-footer">
      <div class="container">
        <p>&copy; {currentYear} Panel Maker Simetri. All Rights Reserved.</p>
      </div>
    </footer>
    <style>
      #site-footer {
        padding: 3rem 0; background-color: #f4f4f4;
        border-top: 1px solid #eee; text-align: center; color: #666;
      }
      #site-footer .container {
        max-width: 1200px; margin: 0 auto; padding: 0 1.5rem;
      }
      /* Tambahkan ini agar konten tidak tertimpa header */
      #page-content {
        padding-top: 80px; /* Sesuaikan dengan tinggi header Anda */
      }
    </style>
  </body>
</html>
