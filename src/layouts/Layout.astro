---
import Header from '../components/Header.astro';
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  type?: string;
}

const {
  title,
  description = "Sales Panel Listrik Simetri Jakarta",
  image = "/img/logosales.webp",
  url = Astro.url.href,
  type = "website"
} = Astro.props;

const currentYear = new Date().getFullYear();
const siteUrl = "https://salespanelsimetri.com";

const metaImageUrl = image.startsWith('http')
  ? image
  : `${siteUrl}${image.startsWith('/') ? '' : '/'}${image}`;
---
<!doctype html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={url} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={metaImageUrl} />
  <meta property="og:locale" content="id_ID" />
  <meta property="og:site_name" content="Sales Panel Simetri" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={metaImageUrl} />
  <link rel="icon" href="/favicon.ico" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700;800&family=DM+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
  <slot name="head" />
  <ViewTransitions />
  <style is:global>
    :root {
      /* Brand colours */
      --c-primary:    #E8401A;
      --c-primary-dark: #C0320E;
      --c-accent:     #E8401A;   /* alias — used by blog/article pages */
      --c-dark:       #0F1318;
      --c-mid:        #161A1E;
      --c-light:      #F5F5F5;
      --c-text:       #2A2A2A;
      --c-text-muted: #888888;   /* used by blog card dates, sidebar bio */

      /* Typography */
      --font-display: 'Oswald', sans-serif;
      --font-body:    'DM Sans', sans-serif;

      /* Radius */
      --radius-sm:  6px;
      --radius-md:  10px;
      --radius-lg:  14px;

      /* Shadows */
      --shadow:    0 2px 12px rgba(0,0,0,0.07);
      --shadow-lg: 0 8px 32px rgba(0,0,0,0.13);

      /* Transitions */
      --transition: 0.25s ease;
    }

    *, *::before, *::after {
      margin: 0; padding: 0;
      box-sizing: border-box;
      min-width: 0; /* ← kunci fix overflow di grid/flex */
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: white;
      color: var(--c-text);
      overflow-x: hidden;
      /* Pastikan tidak ada yang keluar layar */
      max-width: 100vw;
    }

    img { max-width: 100%; display: block; height: auto; }
    a { text-decoration: none; color: inherit; }

    .container {
      width: min(1200px, calc(100% - 40px));
      margin-inline: auto;
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="footer-top-line"></div>
    <div class="container footer-grid">
      <div class="footer-brand">
        <img src="/img/logosales.webp" alt="Logo Simetri" class="footer-logo" loading="lazy" />
        <p class="footer-text">Solusi panel listrik terpercaya untuk industri dan gedung di seluruh Indonesia.</p>
        <a href="https://wa.me/6281213351911" class="footer-wa" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          +62 812-1335-1911
        </a>
      </div>
      <div>
        <h4>Menu</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/about">Tentang</a></li>
          <li><a href="/blog">Blog</a></li>
        </ul>
      </div>
      <div>
        <h4>Kontak</h4>
        <ul>
          <li>+62 812-1335-1911</li>
          <li>Jakarta Barat, DKI Jakarta</li>
          <li style="color:rgba(255,255,255,0.35); font-size:0.82rem; line-height:1.6;">Aries Niaga Blok A1 No. 3A-3B,<br/>Jalan Taman Aries, Meruya Utara</li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom container">
      <span>© {currentYear} Sales Panel Simetri — PT Sinar Metrindo Perkasa</span>
      <span class="footer-bottom-accent">Jakarta, Indonesia</span>
    </div>
  </footer>

  <style>
    .footer { background: #0A0C0E; color: white; }
    .footer-top-line {
      height: 3px;
      background: linear-gradient(90deg, #E8401A, #ff6a45, #E8401A);
      background-size: 200% 100%;
      animation: shimmer 3s linear infinite;
    }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
    .footer-grid {
      display: grid; grid-template-columns: 2fr 1fr 1fr;
      gap: 60px; padding: 70px 0 60px;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .footer-brand { display: flex; flex-direction: column; gap: 18px; }
    .footer-logo { width: 150px; filter: brightness(0) invert(1); opacity: 0.9; }
    .footer-text { color: rgba(255,255,255,.45); line-height: 1.8; font-size: 0.88rem; max-width: 300px; }
    .footer-wa { display: inline-flex; align-items: center; gap: 8px; color: #E8401A; font-weight: 700; font-size: 0.9rem; transition: color 0.2s; }
    .footer-wa:hover { color: #ff6a45; }
    .footer h4 { margin-bottom: 18px; font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.3); }
    .footer ul { list-style: none; display: flex; flex-direction: column; gap: 11px; }
    .footer li, .footer a { color: rgba(255,255,255,.55); font-size: 0.88rem; transition: color 0.2s; }
    .footer a:hover { color: white; }
    .footer-bottom {
      display: flex; align-items: center; justify-content: space-between;
      padding-top: 22px; padding-bottom: 22px;
      color: rgba(255,255,255,.25); font-size: .78rem;
    }
    .footer-bottom-accent { color: rgba(232,64,26,0.5); font-weight: 600; letter-spacing: 0.08em; font-size: 0.72rem; text-transform: uppercase; }
    @media (max-width: 768px) {
      .footer-grid { grid-template-columns: 1fr; gap: 36px; padding: 50px 0 40px; }
      .footer-bottom { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</body>
</html>